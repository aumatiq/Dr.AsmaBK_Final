/**
 * ═══════════════════════════════════════════════════════════
 * AUMATIQ — PWA Setup (manifest.json generator)
 * Dr. Asma Clinic — Doctor Automation System
 * ═══════════════════════════════════════════════════════════
 * এই ফাইলটা নতুন — Apps Script Editor-এ "+" চেপে নতুন Script file
 * বানিয়ে নাম দাও ঠিক এভাবে:  PWASetup
 * (এক্সটেনশন .gs নিজে থেকেই যোগ হবে, শুধু "PWASetup" লিখলেই হবে)
 *
 * এই ফাইল কী করে:
 * ১. icon-192.png ও icon-512.png কে base64 আকারে ভেতরেই রাখে
 *    (Apps Script raw PNG serve করতে পারে না, তাই data-URI ব্যবহার)
 * ২. দুইটা আলাদা manifest.json বানায় — একটা Public Website-এর জন্য,
 *    একটা Doctor Dashboard-এর জন্য (আলাদা name/icon/start_url সহ)
 * ৩. Code.gs-এর doGet() থেকে এই manifest গুলো serve করা হয়
 *    (Code.gs-এ কী যোগ করতে হবে, সেটা আলাদা নির্দেশনায় দেওয়া আছে)
 * ═══════════════════════════════════════════════════════════
 */

// ── আইকন — base64 (Apps Script-এ আসল .png ফাইল আপলোড করা যায় না,
//     তাই এটাই সবচেয়ে নির্ভরযোগ্য পদ্ধতি) ──
const ICON_192_BASE64 = "";

const ICON_512_BASE64 = "";

// ── Data-URI বানানোর হেল্পার ──
function getIcon192DataUri_() {
  return "data:image/png;base64," + ICON_192_BASE64;
}
function getIcon512DataUri_() {
  return "data:image/png;base64," + ICON_512_BASE64;
}

// ─────────────────────────────────────────────────────────────
// PUBLIC WEBSITE — manifest.json content
// ─────────────────────────────────────────────────────────────
function getPublicManifestJson_() {
  var base = ScriptApp.getService().getUrl(); // চলমান deployment-এর আসল /exec URL, নিজে থেকেই সঠিক থাকবে
  return {
    "name": "Dr. Asma Clinic \u2014 Patient Portal",
    "short_name": "Dr. Asma Clinic",
    "description": "Book appointments, view test results, and stay in touch with Dr. Asma's Clinic.",
    "start_url": base,
    "id": base,
    "scope": base,
    "display": "standalone",
    "orientation": "portrait",
    "background_color": "#0A0A0F",
    "theme_color": "#4F46E5",
    "icons": [
      { "src": getIcon192DataUri_(), "sizes": "192x192", "type": "image/png", "purpose": "any" },
      { "src": getIcon512DataUri_(), "sizes": "512x512", "type": "image/png", "purpose": "any" },
      { "src": getIcon192DataUri_(), "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
      { "src": getIcon512DataUri_(), "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
    ]
  };
}

// ─────────────────────────────────────────────────────────────
// DOCTOR DASHBOARD — manifest.json content (আলাদা app হিসেবে install হবে)
// ─────────────────────────────────────────────────────────────
function getDashboardManifestJson_() {
  var base = ScriptApp.getService().getUrl();
  var dashUrl = base + "?page=dashboard";
  return {
    "name": "Dr. Asma Clinic \u2014 Doctor Dashboard",
    "short_name": "Clinic Dashboard",
    "description": "Internal dashboard for Dr. Asma's Clinic staff \u2014 patients, appointments, tests, and follow-ups.",
    "start_url": dashUrl,
    "id": dashUrl,
    "scope": base,
    "display": "standalone",
    "orientation": "portrait",
    "background_color": "#0A0A0F",
    "theme_color": "#F5A623",
    "icons": [
      { "src": getIcon192DataUri_(), "sizes": "192x192", "type": "image/png", "purpose": "any" },
      { "src": getIcon512DataUri_(), "sizes": "512x512", "type": "image/png", "purpose": "any" },
      { "src": getIcon192DataUri_(), "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
      { "src": getIcon512DataUri_(), "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
    ]
  };
}
